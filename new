    const fee = stakeEntry;
    const rake = selectedTier?.rake || 0;
    const netPool = selectedTier ? selectedTier.poolEntry : (activeTournament.poolEntry || activeTournament.entry);
    const can = balance >= fee;
    const champion = predictions[`r${totalRounds-1}-m0`];
    const existingCount = getBracketCount(activeTournament.id);
    const maxReached = existingCount >= MAX_BRACKETS_PER_TOURNAMENT;
    const earlyBonus = getEarlyBirdBonus(activeTournament);
