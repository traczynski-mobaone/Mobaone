              </div>
            )}
          </div>
          {/* Bracket # indicator */}
          {existingCount > 0 && (
            <div style={{background:C.accentLight,borderRadius:8,padding:10,marginBottom:16,display:'flex',alignItems:'center',gap:8}}>
              <span style={{fontSize:13,color:C.accentText}}>Bracket #{existingCount + 1} for {activeTournament.name}</span>
            </div>
