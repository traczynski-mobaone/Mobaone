const getBracketSize = t => !t ? 32 : (t.type==='grandslam'||t.type==='atp1000') ? 128 : t.type==='atp500' ? 64 : 32;
const getRounds = t => {
  const s = getBracketSize(t);
  if (s===128) return [{name:'R128',matches:64,pts:1},{name:'R64',matches:32,pts:2},{name:'R32',matches:16,pts:3},{name:'R16',matches:8,pts:5},{name:'QF',matches:4,pts:8},{name:'SF',matches:2,pts:13},{name:'F',matches:1,pts:21}];
  if (s===64)  return [{name:'R32',matches:16,pts:1},{name:'R16',matches:8,pts:2},{name:'QF',matches:4,pts:3},{name:'SF',matches:2,pts:5},{name:'F',matches:1,pts:8}];
  return [{name:'R16',matches:8,pts:1},{name:'QF',matches:4,pts:2},{name:'SF',matches:2,pts:3},{name:'F',matches:1,pts:5}];
};
const getBlackHorse = (bracketSize) => {
  if (bracketSize===128) return indianWellsDraw.filter(p=>p.seed===null||(typeof p.seed==='number'&&p.seed>32)).map(p=>({id:p.pos,name:p.name,seed:p.seed,flag:p.flag}));
  if (bracketSize===64)  return atpPlayers.filter(p=>p.seed>=17);
  return atpPlayers.filter(p=>p.seed>=9);
};
const calcPrizePool = (entries, poolEntry) => entries * poolEntry;

