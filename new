// Prize pool for a given stake
const getPoolEntry = (stake) => stake.poolEntry;
const getStakePool = (stake) => stake.mockEntries * stake.poolEntry;
const getStakeRake = (stake) => stake.rake;

// ─── GUARANTEED PRIZE POOL ────────────────────────────────────────────────────
// Each stake level gets a proportional share of the guarantee
// Share = (stake.poolEntry / total_pool_entry_across_all_stakes) * guaranteed
const getTotalPoolWeight = () => STAKES.reduce((s, st) => s + st.poolEntry * st.mockEntries, 0);

const getGuaranteedForStake = (stake, tournament) => {
  if (!tournament?.guaranteed) return 0;
  const weight = (stake.poolEntry * stake.mockEntries) / getTotalPoolWeight();
  return Math.round(tournament.guaranteed * weight);
};

// Effective pool = max(natural pool, guaranteed share)
const getEffectivePool = (stake, tournament) => {
  const natural = getStakePool(stake);
  const guaranteed = getGuaranteedForStake(stake, tournament);
  return Math.max(natural, guaranteed);
};

// Overlay = how much organiser tops up (guaranteed - natural, if positive)
const getOverlay = (stake, tournament) => {
  const natural = getStakePool(stake);
  const guaranteed = getGuaranteedForStake(stake, tournament);
  return Math.max(0, guaranteed - natural);
};

// Total guaranteed pool across ALL stakes for a tournament
const getTotalGuaranteedPool = (tournament) => {
  if (!tournament?.guaranteed) return STAKES.reduce((s, st) => s + getStakePool(st), 0);
  return Math.max(
    STAKES.reduce((s, st) => s + getStakePool(st), 0),
    tournament.guaranteed
  );
};



