          </div>

          {/* Early Bird bonus */}
          {earlyBonus > 0 && (
            <div style={{background:`${C.green}12`,border:`1px solid ${C.green}`,borderRadius:10,padding:12,marginBottom:16,display:'flex',alignItems:'center',gap:8}}>
              <span style={{fontSize:18}}></span>
              <div>
                <p style={{fontSize:13,fontWeight:600,color:C.green,margin:0}}>Early Bird Bonus Active!</p>
