                  const newBracket = {
                    id: Date.now(),
                    name: bracketName || defaultName,
                    bracketNum: existingCount + 1,
                    tier: selectedTier,
                    tournament: activeTournament,
                    champion,
                    blackHorse,
                    predictions: { ...predictions },
